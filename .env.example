# ══════════════════════════════════════════════════════════════
#  AlphaEdge v3 — Environment Configuration
# ══════════════════════════════════════════════════════════════

# ── REQUIRED ──

# Gemini API Key (server-side only — NEVER expose in frontend)
GEMINI_API_KEY=your-gemini-api-key-here

# PostgreSQL connection (with pgvector extension)
DATABASE_URL=postgresql://alpha:alpha@localhost:5432/alphaedge

# ── OPTIONAL ──

# Gemini model (default: gemini-2.5-flash)
# Options: gemini-2.5-flash, gemini-2.5-pro, gemini-2.0-flash
GEMINI_MODEL=gemini-2.5-flash

# ── Scoring Parameters ──
SCORE_THRESHOLD=65
LOGISTIC_K=0.08
LOGISTIC_C=55

# ── Score Weights (must sum to 1.0) ──
W_MACRO=0.30
W_THEME=0.25
W_PAM=0.45

# ── Risk Management ──
KELLY_FRACTION=0.25
MAX_POSITION_PCT=5.0
MAX_RISK_PER_TRADE_PCT=2.0
MAX_PORTFOLIO_HEAT_PCT=6.0
PORTFOLIO_SIZE=100000
